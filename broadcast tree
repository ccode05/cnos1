#include <stdio.h>
int main(){
    int a[10][10],n,i,j,r;
    printf("Enter number of nodes: ");scanf("%d",&n);
    printf("Enter adjacency matrix:\n");
    for(i=1;i<=n;i++)for(j=1;j<=n;j++){
        printf("Is there a connection from %d to %d (1/0)? ",i,j);
        scanf("%d",&a[i][j]);
    }
    printf("Enter root node: ");scanf("%d",&r);
    printf("\nAdjacent nodes of %d: \n",r);
    for(j=1;j<=n;j++)if(a[r][j]||a[j][r])printf("%d\t",j);
    printf("\n\nNon-adjacent nodes of %d: \n",r);
    for(j=1;j<=n;j++)if(j!=r&&!a[r][j]&&!a[j][r])printf("%d\t",j);
    printf("\n");
}
