#include <stdio.h>

int main()
{
    int n, i;
    int st[100];
    char op;

    do
    {
        printf("\nHow many stations: ");
        scanf("%d", &n);

        printf("\nEnter status of stations (0 or 1)\n");

        for(i = 0; i < n; i++)
        {
            printf("Enter status of station %d: ", i + 1);
            scanf("%d", &st[i]);
        }

        printf("\n");

        for(i = 0; i < n; i++)
        {
            if(st[i] == 1)
            {
                printf("Station %d is ready to transmit\n", i + 1);
            }
        }

        printf("\nRepeat? press y/Y: ");
        scanf(" %c", &op);

    } while(op == 'y' || op == 'Y');

    return 0;
}
